# Envoi des e-mails du formulaire de contact (https://resend.com)
# Sans clé, les demandes sont journalisées dans la console serveur (mode dev).
RESEND_API_KEY=

# Destinataire et expéditeur des demandes de contact
CONTACT_TO=atelier@maisonverdier.fr
CONTACT_FROM="Site Maison Verdier <onboarding@resend.dev>"
